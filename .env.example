# Live LLM provider metadata.
# Store the real API key in the OS secret store when available:
#   npm run secret:llm -- set --value-env COWORK_OPENAI_API_KEY
# Keep this file placeholder-only. Do not commit a real API key here.

COWORK_LLM_PROVIDER_MODE=openai
COWORK_OPENAI_PROVIDER_LABEL=OpenAI
COWORK_OPENAI_BASE_URL=https://api.openai.com/v1
COWORK_OPENAI_MODEL=gpt-4.1-mini
# Optional per-stage overrides. Leave aligned unless you are intentionally splitting roles.
# COWORK_OPENAI_PRIMARY_MODEL=gpt-4.1-mini
# COWORK_OPENAI_UTILITY_MODEL=gpt-4.1-mini
# COWORK_OPENAI_VISION_MODEL=gpt-4.1-mini

# Leave blank to use the default Authorization: Bearer <key> header.
COWORK_OPENAI_API_KEY_HEADER=
COWORK_OPENAI_API_KEY_PREFIX=
# Optional last-resort local fallback only when OS secret-store is unavailable.
# COWORK_OPENAI_API_KEY=

# Windows-first local operator posture.
COWORK_LLM_RUNTIME_PROFILE=production_strict
COWORK_LLM_PRODUCTION_STRICT=1
COWORK_LLM_REQUIRE_OS_SECRET_STORE=1
COWORK_LLM_ALLOW_MOCK_FALLBACK=0
COWORK_LLM_ALLOW_DETERMINISTIC_FALLBACK=0
COWORK_LLM_LOG_SCOPE=runtime

# Optional budget and timeout tuning.
COWORK_OPENAI_TIMEOUT_MS=30000
COWORK_LLM_BUDGET_PER_RUN_TOKENS=50000
COWORK_LLM_BUDGET_PER_SESSION_TOKENS=250000
COWORK_LLM_BUDGET_PER_RUN_USD=0.5
COWORK_LLM_BUDGET_PER_SESSION_USD=2

# Optional live/real-surface validation configs.
# COWORK_REAL_SURFACE_CONFIG_PATH=
# COWORK_REAL_SURFACE_SMOKE_CONFIG_PATH=

# Optional pricing overrides to enable estimated USD cost tracking.
# COWORK_OPENAI_PRIMARY_INPUT_USD_PER_1K=
# COWORK_OPENAI_PRIMARY_OUTPUT_USD_PER_1K=
# COWORK_OPENAI_UTILITY_INPUT_USD_PER_1K=
# COWORK_OPENAI_UTILITY_OUTPUT_USD_PER_1K=
# COWORK_OPENAI_VISION_INPUT_USD_PER_1K=
# COWORK_OPENAI_VISION_OUTPUT_USD_PER_1K=
